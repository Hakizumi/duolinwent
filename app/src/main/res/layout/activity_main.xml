<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainActivity">

    <!-- Background image -->
    <ImageView
            android:id="@+id/bgImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:src="@drawable/icon"
            android:contentDescription="@string/app_name"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <!-- Root-level anchor matching the spacer position inside contentCard. -->
    <TextView
            android:id="@+id/projectNameAnchor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:text="@string/app_name"
            android:textColor="@android:color/transparent"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="@font/fulu_steed_2"
            android:maxLines="1"
            android:lineSpacingExtra="6dp"
            app:layout_constraintTop_toTopOf="@id/contentCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <!-- Project name -->
    <HorizontalScrollView
            android:id="@+id/projectNameScroll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fillViewport="true"
            android:gravity="center_horizontal"
            android:scrollbars="none"
            app:layout_constraintTop_toTopOf="@id/projectNameAnchor"
            app:layout_constraintBottom_toBottomOf="@id/projectNameAnchor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <TextView
                android:id="@+id/tvProjectName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/app_name"
                android:textColor="#22EB3A"
                android:textSize="48sp"
                android:textStyle="bold"
                android:fontFamily="@font/fulu_steed_2"
                android:maxLines="1"
                android:singleLine="true"
                android:lineSpacingExtra="6dp" />

    </HorizontalScrollView>

    <!-- Content layout -->
    <LinearLayout
            android:id="@+id/contentCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:elevation="12dp"
            app:layout_constraintWidth_percent="0.88"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <!-- Placeholder transparent project name -->
        <TextView
                android:id="@+id/tvProjectNameSpacer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/app_name"
                android:textColor="@android:color/transparent"
                android:textSize="48sp"
                android:textStyle="bold"
                android:fontFamily="@font/fulu_steed_2"
                android:maxLines="1"
                android:lineSpacingExtra="6dp" />

        <!-- Project introduce -->
        <TextView
                android:id="@+id/tvProjectIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/project_introduce"
                android:textColor="#BBC0CC"
                android:textSize="22sp"
                android:fontFamily="@font/rastano_3"
                android:lineSpacingExtra="6dp" />

        <!-- Divider line -->
        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:background="#33FFFFFF" />

        <!-- Usage -->
        <TextView
                android:id="@+id/tvProjectUsage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/project_usage"
                android:textColor="#3F3F3F"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/just_a_kiss_2"
                android:lineSpacingExtra="6dp" />

        <!-- GitHub button -->
        <Button
                android:id="@+id/btnGithub"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:text="@string/github_button"
                android:textColor="#807E7E"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:textAllCaps="false"
                android:background="@android:color/transparent" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>